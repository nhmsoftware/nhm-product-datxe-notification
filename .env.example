# Server
PORT=3003
HOST=0.0.0.0

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_COMMUNICATION_CHANNEL=ride.communication.events
REDIS_FINANCE_CHANNEL=finance.events

# Backend API (để lấy device token)
BACKEND_API_URL=http://localhost:8000
# JWT secret phải khớp với JWT_SECRET trong .env của Laravel
BACKEND_JWT_SECRET=your_shared_jwt_secret_here

# Firebase FCM v1 (Service Account JSON)
FIREBASE_SERVICE_ACCOUNT_PATH=/var/www/html/nhm-product-datxe-notification/firebase-service-account.json
