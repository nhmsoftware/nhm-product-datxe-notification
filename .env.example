# Server
PORT=3003
HOST=0.0.0.0

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_COMMUNICATION_CHANNEL=ride.communication.events
REDIS_FINANCE_CHANNEL=finance.events

# Backend API (để lấy device token)
BACKEND_API_URL=http://localhost:8000
# JWT secret phải khớp với JWT_SECRET trong .env của Laravel
BACKEND_JWT_SECRET=your_shared_jwt_secret_here

# Push Notification Provider
# URL của HTTP endpoint provider push (VD: https://fcm.googleapis.com/fcm/send hoặc provider khác)
PUSH_PROVIDER_URL=https://your-push-provider.com/send
PUSH_PROVIDER_API_KEY=your_push_provider_api_key_here
